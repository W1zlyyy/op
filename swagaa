def get_setting(key, default=None):
    row = cursor.execute(
        "SELECT value FROM settings WHERE key=?",
        (key,)
    ).fetchone()
    return row[0] if row else default


def set_setting(key, value):
    cursor.execute(
        "REPLACE INTO settings (key, value) VALUES (?, ?)",
        (key, str(value))
    )
    conn.commit()


def set_setting_if_missing(key, value):
    exists = cursor.execute(
        "SELECT 1 FROM settings WHERE key=?",
        (key,)
    ).fetchone()
    if not exists:
        set_setting(key, value)


def is_admin(user_id: int) -> bool:
    row = cursor.execute(
        "SELECT 1 FROM admins WHERE user_id=?",
        (user_id,)
    ).fetchone()
    return bool(row)


def flyer_enabled() -> bool:
    return str(get_setting("flyer_enabled", "1")) == "1"


def current_markup() -> int:
    try:
        return int(get_setting("markup", "0") or 0)
    except Exception:
        return 0


def current_price() -> int:
    return BASE_PRICE + current_markup()


async def send_log(text: str):
    log_chat = get_setting("log_chat", "")
    if not log_chat:
        return
    try:
        await bot.send_message(int(log_chat), text)
    except Exception as e:
        logging.warning(f"Не удалось отправить лог: {e}")


def get_username_text(user: Message | CallbackQuery) -> str:
    from_user = user.from_user
    if from_user.username:
        return f"@{from_user.username}"
    return "нет"


