@dp.message(F.successful_payment)
async def successful_payment(message: Message):
    state = user_state.get(message.from_user.id)
    if not state:
        await message.answer("Не удалось найти данные заказа. Попробуй снова.")
        return

    try:
        await bot.send_gift(
            user_id=message.from_user.id,
            gift_id=state["gift_id"],
            text=state.get("comment", ""),
            is_anonymous=state.get("anonymous", False)
        )

        cursor.execute(
            """
            INSERT INTO orders (user_id, gift, gift_id, price, comment, anonymous, created_at)
            VALUES (?, ?, ?, ?, ?, ?, ?)
            """,
            (
                message.from_user.id,
                state["gift_name"],
                state["gift_id"],
                message.successful_payment.total_amount,
                state.get("comment", ""),
                1 if state.get("anonymous", False) else 0,
                datetime.now().isoformat()
            )
        )
        conn.commit()

        username = message.from_user.username or "нет"

        await send_log(
            f"💰 <b>Новая покупка</b>\n"
            f"👤 Username: {('@' + username) if username != 'нет' else 'нет'}\n"
            f"🆔 ID: <code>{message.from_user.id}</code>\n"
            f"🎁 Подарок: <b>{state['gift_name']}</b>\n"
            f"💵 Сумма: <b>{message.successful_payment.total_amount} Stars</b>\n"
            f"🎭 Анонимно: <b>{'Да' if state.get('anonymous') else 'Нет'}</b>\n"
            f"💬 Комментарий: <b>{state.get('comment') or 'нет'}</b>"
        )

        await message.answer("✅ Оплата прошла успешно.\n🎁 Подарок отправлен.")
    except Exception as e:
        logging.exception("Gift send error")
        await send_log(
            f"❌ <b>Ошибка выдачи подарка</b>\n"
            f"🆔 Пользователь: <code>{message.from_user.id}</code>\n"
            f"🎁 Подарок: <b>{state.get('gift_name')}</b>\n"
            f"Ошибка: <code>{e}</code>"
        )
        await message.answer(
            "❌ Оплата получена, но при отправке подарка возникла ошибка. Администратор увидит это в логах."
        )

    user_state.pop(message.from_user.id, None)


