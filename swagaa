# UNIVERSAL MESSAGE HANDLER
# =========================
@dp.message()
async def universal_message_handler(message: Message):
    state = user_state.get(message.from_user.id)
    if not state:
        return

    admin_action = state.get("admin_action")
    if admin_action and is_admin(message.from_user.id):
        if admin_action == "set_markup":
            try:
                value = int(message.text.strip())
                if value < 0:
                    await message.answer("❌ Наценка не может быть меньше 0.")
                    return

                set_setting("markup", value)
                user_state.pop(message.from_user.id, None)

                await message.answer(
                    "✅ <b>Наценка обновлена</b>\n\n"
                    f"Новая наценка: <b>{value} Stars</b>\n"
                    f"Новая цена подарка: <b>{BASE_PRICE + value} Stars</b>",
                    reply_markup=admin_menu_kb()
                )
                return
            except ValueError:
                await message.answer("❌ Пришли число. Например: <code>10</code>")
                return

        if admin_action == "set_log_chat":
            try:
                chat_id = int(message.text.strip())
                set_setting("log_chat", chat_id)
                user_state.pop(message.from_user.id, None)

                await message.answer(
                    "✅ <b>Лог-чат обновлён</b>\n\n"
                    f"Новый чат для логов: <code>{chat_id}</code>",
                    reply_markup=admin_menu_kb()
                )
                return
            except ValueError:
                await message.answer("❌ Пришли корректный ID чата числом.")
                return

    if state.get("awaiting_comment"):
        state["comment"] = message.text
        state["awaiting_comment"] = False
        await create_invoice_for_user(
            message.from_user.id,
            message.from_user.language_code
        )
        await message.answer(
            "💳 Инвойс отправлен. Оплати его, и подарок будет выслан автоматически."
        )
        return


