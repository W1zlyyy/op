async def ensure_user_registered(message: Message):
    user_id = message.from_user.id
    username = message.from_user.username or ""

    args = message.text.split()
    referrer_id = None
    if len(args) > 1 and args[1].startswith("ref_"):
        try:
            referrer_id = int(args[1].replace("ref_", ""))
        except Exception:
            referrer_id = None

    existing = cursor.execute(
        "SELECT user_id FROM users WHERE user_id=?",
        (user_id,)
    ).fetchone()

    now = datetime.now().isoformat()

    cursor.execute(
        """
        INSERT OR IGNORE INTO users (user_id, username, referrer_id, created_at)
        VALUES (?, ?, ?, ?)
        """,
        (user_id, username, referrer_id, now)
    )
    conn.commit()

    cursor.execute(
        """
        UPDATE users
        SET username = ?,
            referrer_id = COALESCE(referrer_id, ?),
            created_at = COALESCE(created_at, ?)
        WHERE user_id = ?
        """,
        (username, referrer_id, now, user_id)
    )
    conn.commit()

    if not existing:
        await send_log(
            f"🆕 <b>Новая регистрация</b>\n"
            f"👤 Username: {('@' + username) if username else 'нет'}\n"
            f"🆔 ID: <code>{user_id}</code>"
        )

        if referrer_id and referrer_id != user_id:
            await send_log(
                f"👥 <b>Новый приглашённый пользователь</b>\n"
                f"👤 Username: {('@' + username) if username else 'нет'}\n"
                f"🆔 ID: <code>{user_id}</code>\n"
                f"🔗 Пригласил: <code>{referrer_id}</code>"
            )


