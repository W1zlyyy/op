async def ensure_flyer_access(user_id: int, language_code: str | None) -> bool:
    """Проверяет, выполнил ли пользователь задания Flyer.
       Возвращает True, если задания выполнены или Flyer выключен.
       Если задания не выполнены — отправляет сообщение с ними и возвращает False."""
    if not flyer_enabled():
        return True

    try:
        msg = flyer_message()
        result = await flyer.check(
            user_id=user_id,
            language_code=language_code or "ru",
            message=msg
        )

        # Универсальная обработка ответа
        if isinstance(result, dict):
            ok = result.get("skip", False)
        elif isinstance(result, bool):
            ok = result
        else:
            ok = True  # fallback (например, если вернулся None)

        if not ok:
            # Отправляем пользователю окно с заданиями (если библиотека сама не отправила)
            # Пытаемся вызвать метод send (название может отличаться в зависимости от версии)
            if hasattr(flyer, "send"):
                await flyer.send(
                    user_id=user_id,
                    language_code=language_code or "ru",
                    message=msg
                )
            elif hasattr(flyer, "ask"):
                await flyer.ask(
                    user_id=user_id,
                    language_code=language_code or "ru",
                    message=msg
                )
            else:
                # Если нет подходящего метода, просто возвращаем False (пользователь не пройдёт проверку)
                logging.warning("Flyer: нет метода send/ask, не могу отправить задания")
        return ok

    except Exception as e:
        logging.exception("Flyer check error")
        await send_log(
            f"⚠️ <b>Ошибка Flyer</b>\n"
            f"🆔 User: <code>{user_id}</code>\n"
            f"Ошибка: <code>{e}</code>"
        )
        # При ошибке лучше пропустить проверку, чтобы не блокировать пользователей
        return True


