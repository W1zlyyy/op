async def create_invoice_for_user(user_id: int, language_code: str | None):
    state = user_state.get(user_id)
    if not state:
        return

    ok = await ensure_flyer_access(user_id, language_code)
    if not ok:
        await bot.send_message(
            user_id,
            "❌ Сначала выполни все задания Flyer, потом повтори покупку."
        )
        return

    price = current_price()
    state["price"] = price
    state["payload"] = f"gift_buy:{user_id}:{int(datetime.now().timestamp())}"

    prices = [LabeledPrice(label=f"Подарок: {state['gift_name']}", amount=price)]

    await bot.send_invoice(
        chat_id=user_id,
        title="Покупка подарка",
        description=(
            f"Подарок: {state['gift_name']}\n"
            f"Комментарий: {'есть' if state.get('comment') else 'нет'}\n"
            f"Отправка: {'анонимная' if state.get('anonymous') else 'обычная'}"
        ),
        payload=state["payload"],
        provider_token="",
        currency="XTR",
        prices=prices
    )


